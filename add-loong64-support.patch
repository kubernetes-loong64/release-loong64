 			$(BUILD_ARGS) \
 			.; \
 	done
@@ -57,8 +60,9 @@ push: container
 	@for platform in $(PLATFORMS); do \
 		echo "Pushing tags for $${platform} platform"; \
 		docker push $(IMAGE)-$${platform##*/}:$(IMAGE_VERSION); \
